    urgent_workspace   #FF5555 #FF5555 #F8F8F2
    # binding_mode       #FF5555 #FF5555 #282a36
  }

  position top
  status_command i3status -c ~/.i3/i3status.conf 
  font pango:DejaVu Sans Mono, FontAwesome 10 

